# ==========================================
# FRONTEND - NEXT.JS - Variables de entorno
# ==========================================
# Copia este archivo como .env.local para desarrollo

# URL pública del sitio web (frontend)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL del backend Strapi (accesible desde el navegador para llamadas client-side)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Token de API de Strapi (solo para llamadas server-side - NO exponer al cliente)
# Generarlo en: Strapi Admin > Settings > API Tokens
STRAPI_API_TOKEN=your_strapi_api_token_here

# Hostname de Strapi (para next.config.js imágenes)
STRAPI_HOST=localhost
