{
  "kind": "singleType",
  "collectionName": "home_pages",
  "info": {
    "singularName": "home-page",
    "pluralName": "home-pages",
    "displayName": "Página de Inicio",
    "description": "Contenido de la página de inicio"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "heroTitle": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "heroSubtitle": {
      "type": "text",
      "required": true
    },
    "heroButtonText": {
      "type": "string",
      "default": "Solicitar información",
      "maxLength": 50
    },
    "heroButtonLink": {
      "type": "string",
      "default": "/contacto"
    },
    "aboutTitle": {
      "type": "string",
      "maxLength": 200
    },
    "aboutText": {
      "type": "text"
    },
    "benefits": {
      "type": "component",
      "repeatable": true,
      "component": "shared.benefit"
    },
    "finalCtaTitle": {
      "type": "string",
      "maxLength": 200
    },
    "finalCtaText": {
      "type": "text"
    },
    "seoTitle": {
      "type": "string",
      "maxLength": 70
    },
    "seoDescription": {
      "type": "text",
      "maxLength": 160
    }
  }
}
