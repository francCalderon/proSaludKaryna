# ==========================================
# BACKEND - STRAPI - Variables de entorno
# ==========================================
# Copia este archivo como .env para desarrollo

# Servidor
HOST=0.0.0.0
PORT=1337

# URL pública del admin (para producción)
PUBLIC_URL=http://localhost:1337

# Seguridad (generar valores únicos con: openssl rand -base64 32)
APP_KEYS=clave1base64aqui,clave2base64aqui,clave3base64aqui,clave4base64aqui
API_TOKEN_SALT=generarTokenSaltUnico32chars
ADMIN_JWT_SECRET=generarAdminJwtSecretUnico32chars
TRANSFER_TOKEN_SALT=generarTransferTokenSaltUnico32chars
JWT_SECRET=generarJwtSecretUnico32chars

# Base de datos (PostgreSQL)
# Para desarrollo local con PostgreSQL:
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cuidado_enfermeria
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=tu_password_local
DATABASE_SSL=false

# Para Railway (usar DATABASE_URL directamente):
# DATABASE_URL=postgresql://user:password@host:port/dbname

# CORS: URLs del frontend que pueden acceder a la API
# En producción: https://tu-dominio-vercel.vercel.app
CORS_ORIGIN=http://localhost:3000

# Email (opcional - para notificaciones)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@email.com
# SMTP_PASS=tu_app_password
