# ==========================================
# BACKEND - STRAPI - Variables de entorno
# ==========================================
# Copia este archivo como .env y completa los valores.
#
# BASE DE DATOS:
#   - LOCAL (desarrollo): no configurar DATABASE_CLIENT
#     Strapi usará SQLite automáticamente (.tmp/data.db)
#   - PRODUCCIÓN (cPanel): configurar DATABASE_CLIENT=mysql
#     y el resto de variables DATABASE_* con los datos de phpMyAdmin

# Servidor
HOST=0.0.0.0
PORT=1337

# URL pública (cambiar en producción)
PUBLIC_URL=http://localhost:1337

# Seguridad — generar valores únicos con: openssl rand -base64 32
APP_KEYS=clave1base64aqui,clave2base64aqui,clave3base64aqui,clave4base64aqui
API_TOKEN_SALT=generarTokenSaltUnico32chars
ADMIN_JWT_SECRET=generarAdminJwtSecretUnico32chars
TRANSFER_TOKEN_SALT=generarTransferTokenSaltUnico32chars
JWT_SECRET=generarJwtSecretUnico32chars

# ──────────────────────────────────────────
# BASE DE DATOS LOCAL — SQLite (predeterminado)
# No se requieren variables adicionales.
# Los datos se guardan en backend/.tmp/data.db
# ──────────────────────────────────────────

# ──────────────────────────────────────────
# BASE DE DATOS PRODUCCIÓN — MySQL (cPanel)
# Descomentar y completar para producción:
# ──────────────────────────────────────────
# DATABASE_CLIENT=mysql
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_NAME=asitlpen_prosalud
# DATABASE_USERNAME=asitlpen_strapi
# DATABASE_PASSWORD=tu_password_mysql
# DATABASE_SSL=false

# CORS — dominio del frontend que puede acceder al API
# Desarrollo: http://localhost:3000
# Producción: https://prosalud.cl
CORS_ORIGIN=http://localhost:3000
