# ==========================================
# GITIGNORE - BACKEND (Strapi)
# ==========================================

# Dependencias
node_modules/
.pnp
.pnp.js

# Strapi build y caché
dist/
build/
.cache/
.strapi/
.strapi-updater.json

# Base de datos SQLite (solo desarrollo)
.tmp/
*.db
*.db-journal

# Uploads locales (no subir archivos de usuarios al repo)
public/uploads/
!public/uploads/.gitkeep

# Variables de entorno con secretos
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Sistema
.DS_Store
Thumbs.db
